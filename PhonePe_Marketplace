<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PhonePe Shop — Marketplace Prototype</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: #F3F4F6;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 2rem 1rem;
}

.phone-wrap {
  display: flex;
  justify-content: center;
  padding: 2rem 1rem;
  background: #E5E7EB;
  border-radius: 24px;
}

.phone {
  width: 360px;
  min-height: 720px;
  background: #F7F7F8;
  border-radius: 36px;
  border: 8px solid #1A1A1A;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.status-bar {
  background: #5F259F;
  padding: 8px 20px 6px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.status-bar span { color: #fff; font-size: 11px; font-weight: 500; }

.top-bar {
  background: #5F259F;
  padding: 10px 16px 14px;
}
.top-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.logo { color: #fff; font-size: 17px; font-weight: 500; letter-spacing: -0.3px; }
.logo span { color: #A78BFA; }
.top-icons { display: flex; gap: 14px; }
.top-icons svg { width: 20px; height: 20px; fill: none; stroke: #fff; stroke-width: 1.8; }

.search-bar {
  background: #fff;
  border-radius: 10px;
  display: flex;
  align-items: center;
  padding: 8px 12px;
  gap: 8px;
}
.search-bar svg { width: 16px; height: 16px; fill: none; stroke: #9CA3AF; stroke-width: 2; flex-shrink: 0; }
.search-bar span { color: #9CA3AF; font-size: 13px; }

.scroll-area {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding-bottom: 60px;
  scrollbar-width: none;
}
.scroll-area::-webkit-scrollbar { display: none; }

.cat-nav {
  background: #fff;
  padding: 10px 0 6px;
  display: flex;
  gap: 0;
  overflow-x: auto;
  border-bottom: 0.5px solid #E5E7EB;
  scrollbar-width: none;
}
.cat-nav::-webkit-scrollbar { display: none; }
.cat-pill {
  flex-shrink: 0;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 500;
  color: #6B7280;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: color 0.15s;
}
.cat-pill.active { color: #5F259F; border-bottom-color: #5F259F; }

.section { padding: 14px 14px 4px; }
.section-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.section-hdr h3 { font-size: 14px; font-weight: 500; color: #111; }
.section-hdr span { font-size: 12px; color: #5F259F; cursor: pointer; }

.subcat-scroll { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 6px; scrollbar-width: none; }
.subcat-scroll::-webkit-scrollbar { display: none; }
.subcat-chip {
  flex-shrink: 0;
  background: #EDE7F6;
  color: #5F259F;
  border-radius: 20px;
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  border: 0.5px solid #C4B5FD;
  white-space: nowrap;
}
.subcat-chip.t2  { background: #E0F7FA; color: #006064; border-color: #80DEEA; }
.subcat-chip.t3f { background: #FCE4EC; color: #880E4F; border-color: #F48FB1; }
.subcat-chip.t3h { background: #E8F5E9; color: #1B5E20; border-color: #A5D6A7; }
.subcat-chip.t3t { background: #E3F2FD; color: #0D47A1; border-color: #90CAF9; }
.subcat-chip.t3e { background: #FFF3E0; color: #E65100; border-color: #FFCC80; }

.banner {
  margin: 14px;
  background: #5F259F;
  border-radius: 14px;
  padding: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.banner-text p:first-child { color: #E9D5FF; font-size: 11px; font-weight: 500; margin-bottom: 4px; }
.banner-text p:last-child  { color: #fff; font-size: 15px; font-weight: 500; line-height: 1.3; }
.banner-btn { background: #fff; color: #5F259F; border-radius: 8px; padding: 8px 14px; font-size: 12px; font-weight: 500; white-space: nowrap; cursor: pointer; border: none; }

.product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 0 14px 14px; }
.product-card { background: #fff; border-radius: 12px; overflow: hidden; border: 0.5px solid #E5E7EB; }
.product-img { height: 100px; display: flex; align-items: center; justify-content: center; font-size: 32px; }
.product-info { padding: 8px 10px 10px; }
.product-info .pname   { font-size: 12px; font-weight: 500; color: #111; line-height: 1.3; margin-bottom: 4px; }
.product-info .pbrand  { font-size: 10px; color: #9CA3AF; margin-bottom: 6px; }
.product-info .prow    { display: flex; align-items: center; justify-content: space-between; }
.product-info .pprice  { font-size: 13px; font-weight: 500; color: #111; }
.product-info .pdiscount { font-size: 10px; color: #16A34A; font-weight: 500; }
.product-info .padd    { background: #5F259F; color: #fff; border: none; border-radius: 6px; padding: 4px 10px; font-size: 11px; cursor: pointer; }

.deals-scroll { display: flex; gap: 10px; overflow-x: auto; padding: 0 14px 14px; scrollbar-width: none; }
.deals-scroll::-webkit-scrollbar { display: none; }
.deal-card { flex-shrink: 0; width: 130px; background: #fff; border-radius: 12px; border: 0.5px solid #E5E7EB; overflow: hidden; }
.deal-badge { background: #5F259F; color: #fff; font-size: 10px; font-weight: 500; padding: 3px 8px; }
.deal-img   { height: 70px; display: flex; align-items: center; justify-content: center; font-size: 26px; }
.deal-info  { padding: 6px 8px 8px; }
.deal-info .dname { font-size: 11px; font-weight: 500; color: #111; margin-bottom: 2px; }
.deal-info .dsave { font-size: 10px; color: #16A34A; font-weight: 500; }

.bottom-nav {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-top: 0.5px solid #E5E7EB;
  display: flex;
  padding: 8px 0 10px;
}
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; }
.nav-item svg  { width: 20px; height: 20px; fill: none; stroke: #9CA3AF; stroke-width: 1.8; }
.nav-item span { font-size: 9px; color: #9CA3AF; }
.nav-item.active svg  { stroke: #5F259F; }
.nav-item.active span { color: #5F259F; }

.tier-label { font-size: 9px; font-weight: 500; padding: 2px 6px; border-radius: 4px; display: inline-block; margin-bottom: 6px; }
.t1-label { background: #EDE7F6; color: #5F259F; }
.t2-label { background: #E0F7FA; color: #006064; }
.t3-label { background: #F3E5F5; color: #6A1B9A; }
</style>
</head>
<body>

<div class="phone-wrap">
  <div class="phone">

    <div class="status-bar">
      <span>9:41</span>
      <span>●●●●○ 4G</span>
    </div>

    <div class="top-bar">
      <div class="top-row">
        <div class="logo">Phone<span>Pe</span> Shop</div>
        <div class="top-icons">
          <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        </div>
      </div>
      <div class="search-bar">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Search across all categories...</span>
      </div>
    </div>

    <div class="cat-nav" id="catNav">
      <div class="cat-pill active" onclick="switchCat(0)">All</div>
      <div class="cat-pill" onclick="switchCat(1)">Electronics</div>
      <div class="cat-pill" onclick="switchCat(2)">Deals</div>
      <div class="cat-pill" onclick="switchCat(3)">Fashion</div>
      <div class="cat-pill" onclick="switchCat(4)">Health</div>
      <div class="cat-pill" onclick="switchCat(5)">Travel</div>
      <div class="cat-pill" onclick="switchCat(6)">Entertainment</div>
    </div>

    <div class="scroll-area">

      <div class="banner">
        <div class="banner-text">
          <p>Exclusive on PhonePe Shop</p>
          <p>0% EMI on top smartphones &amp; gadgets</p>
        </div>
        <button class="banner-btn">Explore</button>
      </div>

      <div class="section">
        <div style="margin-bottom:6px;"><span class="tier-label t1-label">Tier 1 · Electronics &amp; Tech</span></div>
        <div class="section-hdr"><h3>Shop by category</h3><span>See all</span></div>
        <div class="subcat-scroll">
          <div class="subcat-chip">Smartphones</div>
          <div class="subcat-chip">Laptops</div>
          <div class="subcat-chip">Wearables</div>
          <div class="subcat-chip">Smart Home</div>
          <div class="subcat-chip">Audio</div>
          <div class="subcat-chip">Cameras</div>
        </div>
      </div>

      <div class="product-grid">
        <div class="product-card">
          <div class="product-img" style="background:#EDE7F6;">📱</div>
          <div class="product-info">
            <p class="pname">Redmi Note 13 Pro</p>
            <p class="pbrand">Xiaomi</p>
            <div class="prow"><div><p class="pprice">₹24,999</p><p class="pdiscount">12% off</p></div><button class="padd">+ Add</button></div>
          </div>
        </div>
        <div class="product-card">
          <div class="product-img" style="background:#EDE7F6;">⌚</div>
          <div class="product-info">
            <p class="pname">Noise ColorFit Pro 5</p>
            <p class="pbrand">Noise</p>
            <div class="prow"><div><p class="pprice">₹3,499</p><p class="pdiscount">30% off</p></div><button class="padd">+ Add</button></div>
          </div>
        </div>
        <div class="product-card">
          <div class="product-img" style="background:#EDE7F6;">💻</div>
          <div class="product-info">
            <p class="pname">Lenovo IdeaPad Slim 3</p>
            <p class="pbrand">Lenovo</p>
            <div class="prow"><div><p class="pprice">₹42,990</p><p class="pdiscount">8% off</p></div><button class="padd">+ Add</button></div>
          </div>
        </div>
        <div class="product-card">
          <div class="product-img" style="background:#EDE7F6;">🎧</div>
          <div class="product-info">
            <p class="pname">boAt Airdopes 141</p>
            <p class="pbrand">boAt</p>
            <div class="prow"><div><p class="pprice">₹1,299</p><p class="pdiscount">67% off</p></div><button class="padd">+ Add</button></div>
          </div>
        </div>
      </div>

      <div class="section">
        <div style="margin-bottom:6px;"><span class="tier-label t2-label">Tier 2 · Shopping &amp; Deals</span></div>
        <div class="section-hdr"><h3>Today's top deals</h3><span>View all</span></div>
        <div style="margin-bottom:10px;">
          <div class="subcat-scroll">
            <div class="subcat-chip t2">Cashback offers</div>
            <div class="subcat-chip t2">Coupons</div>
            <div class="subcat-chip t2">Price drops</div>
            <div class="subcat-chip t2">Brand sales</div>
            <div class="subcat-chip t2">Trending</div>
          </div>
        </div>
      </div>

      <div class="deals-scroll">
        <div class="deal-card">
          <div class="deal-badge">10% cashback</div>
          <div class="deal-img" style="background:#E0F7FA;">📺</div>
          <div class="deal-info"><p class="dname">Smart TVs</p><p class="dsave">Save up to ₹4,000</p></div>
        </div>
        <div class="deal-card">
          <div class="deal-badge">Flat ₹500 off</div>
          <div class="deal-img" style="background:#E0F7FA;">👟</div>
          <div class="deal-info"><p class="dname">Footwear</p><p class="dsave">Min. order ₹2,000</p></div>
        </div>
        <div class="deal-card">
          <div class="deal-badge">Up to 40% off</div>
          <div class="deal-img" style="background:#E0F7FA;">💄</div>
          <div class="deal-info"><p class="dname">Beauty</p><p class="dsave">Top D2C brands</p></div>
        </div>
        <div class="deal-card">
          <div class="deal-badge">Free upgrade</div>
          <div class="deal-img" style="background:#E0F7FA;">✈️</div>
          <div class="deal-info"><p class="dname">Flights</p><p class="dsave">Book &amp; earn coins</p></div>
        </div>
      </div>

      <div class="section">
        <div style="margin-bottom:6px;"><span class="tier-label t3-label">Tier 3 · Fashion &amp; Beauty</span></div>
        <div class="section-hdr"><h3>Fashion &amp; Beauty</h3><span>See all</span></div>
        <div class="subcat-scroll">
          <div class="subcat-chip t3f">Men's fashion</div>
          <div class="subcat-chip t3f">Women's fashion</div>
          <div class="subcat-chip t3f">Skincare</div>
          <div class="subcat-chip t3f">Makeup</div>
          <div class="subcat-chip t3f">Sustainable brands</div>
          <div class="subcat-chip t3f">Jewellery</div>
        </div>
      </div>

      <div class="section" style="padding-top:4px;">
        <div style="margin-bottom:6px;"><span class="tier-label t3-label">Tier 3 · Health &amp; Wellness</span></div>
        <div class="section-hdr"><h3>Health &amp; Wellness</h3><span>See all</span></div>
        <div class="subcat-scroll">
          <div class="subcat-chip t3h">Supplements</div>
          <div class="subcat-chip t3h">Ayurvedic &amp; herbal</div>
          <div class="subcat-chip t3h">Fitness equipment</div>
          <div class="subcat-chip t3h">Wellness plans</div>
          <div class="subcat-chip t3h">Personal care</div>
          <div class="subcat-chip t3h">Sports nutrition</div>
        </div>
      </div>

      <div class="section" style="padding-top:4px;">
        <div style="margin-bottom:6px;"><span class="tier-label t3-label">Tier 3 · Travel &amp; Tourism</span></div>
        <div class="section-hdr"><h3>Travel &amp; Tourism</h3><span>See all</span></div>
        <div class="subcat-scroll">
          <div class="subcat-chip t3t">Flights</div>
          <div class="subcat-chip t3t">Hotels &amp; stays</div>
          <div class="subcat-chip t3t">Holiday packages</div>
          <div class="subcat-chip t3t">Travel insurance</div>
          <div class="subcat-chip t3t">Car rentals</div>
          <div class="subcat-chip t3t">Experiences</div>
        </div>
      </div>

      <div class="section" style="padding-top:4px;">
        <div style="margin-bottom:6px;"><span class="tier-label t3-label">Tier 3 · Entertainment</span></div>
        <div class="section-hdr"><h3>Entertainment &amp; Subscriptions</h3><span>See all</span></div>
        <div class="subcat-scroll">
          <div class="subcat-chip t3e">OTT plans</div>
          <div class="subcat-chip t3e">Music streaming</div>
          <div class="subcat-chip t3e">Gaming</div>
          <div class="subcat-chip t3e">Fantasy sports</div>
          <div class="subcat-chip t3e">Live events</div>
          <div class="subcat-chip t3e">Gift cards</div>
        </div>
      </div>

    </div>

    <div class="bottom-nav">
      <div class="nav-item active">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Home</span>
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Explore</span>
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span>Cart</span>
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
        <span>Deals</span>
      </div>
      <div class="nav-item">
        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span>Account</span>
      </div>
    </div>

  </div>
</div>

<script>
function switchCat(idx) {
  document.querySelectorAll('.cat-pill').forEach((p, i) => {
    p.classList.toggle('active', i === idx);
  });
}
</script>

</body>
</html>
